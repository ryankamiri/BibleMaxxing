# Copy this file to /opt/biblemaxxing/.env on the VPS and fill real values
# there. Never commit the real .env file.

BIBLEMAXXING_ENV=production

# Docker/Caddy wiring. Get the network name from `docker network ls` and the
# TailorTom Caddy service inspection.
TAILORTOM_CADDY_NETWORK=tailortom_tailortom
BIBLEMAXXING_HOST_PORT=8017
BIBLEMAXXING_API_IMAGE=biblemaxxing-api:local
BIBLEMAXXING_BACKEND_CONTEXT=./backend
BIBLEMAXXING_BACKEND_DOCKERFILE=Dockerfile

# Database. Replace passwords and secrets on the VPS only.
POSTGRES_DB=biblemaxxing
POSTGRES_USER=biblemaxxing
POSTGRES_PASSWORD=replace-with-a-long-random-password
BIBLEMAXXING_DATABASE_URL=postgresql+psycopg://biblemaxxing:replace-with-a-long-random-password@db:5432/biblemaxxing
BIBLEMAXXING_AUTO_CREATE_TABLES=false

# Auth/session secrets.
BIBLEMAXXING_SECRET_KEY=replace-with-a-long-random-secret
BIBLEMAXXING_ACCESS_TOKEN_MINUTES=43200

# YouTube Data API. Official embedded playback only; do not store or serve AV
# media files.
BIBLEMAXXING_YOUTUBE_API_KEY=replace-with-youtube-data-api-key
BIBLEMAXXING_YOUTUBE_INGEST_QUERIES=Jesus Bible shorts|Christian prayer shorts|BibleProject shorts Jesus|Christian discipleship shorts|Scripture encouragement shorts|gospel encouragement shorts|Christian workplace faith shorts|Bible study shorts Jesus|worship shorts Christian|Christian testimony shorts
BIBLEMAXXING_YOUTUBE_INGEST_PASTOR_QUERIES=Philip Anthony Mitchell sermon clips|2819 Church Philip Anthony Mitchell shorts|Bryce Crawford Christian shorts|Bryce Crawford sermon clips|Cliffe Knechtle shorts|Give Me An Answer Cliffe Knechtle shorts|Tim Mackie BibleProject shorts|Gavin Ortlund Truth Unites clips|John Piper sermon clips|Tim Keller sermon clips|David Platt sermon clips|Matt Chandler sermon clips
BIBLEMAXXING_YOUTUBE_INGEST_PASTOR_QUERIES_PER_CYCLE=2
BIBLEMAXXING_YOUTUBE_INGEST_SEARCH_CALLS_PER_CYCLE=6
BIBLEMAXXING_YOUTUBE_INGEST_DAILY_SEARCH_CALL_BUDGET=96
BIBLEMAXXING_YOUTUBE_INGEST_MAX_RESULTS=25
BIBLEMAXXING_YOUTUBE_INGEST_INTERVAL_SECONDS=7200
BIBLEMAXXING_YOUTUBE_INGEST_DEFAULT_APPROVE=true
BIBLEMAXXING_CORS_ORIGINS=*

# Admin bootstrap. Replace values on the VPS only.
# The first registered user becomes admin in the current prototype.
